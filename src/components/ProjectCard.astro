---
/**
 * ProjectCard — editorial card for a single project.
 * Image preview at top, status badge, title, description, tech tags, and optional links below.
 */
import StatusBadge from './StatusBadge.astro';
import type { Status } from './StatusBadge.astro';

interface Props {
  title: string;
  description: string;
  status: Status;
  tags: string[];
  image?: string | null;
  liveUrl?: string | null;
  githubUrl?: string | null;
}

const { title, description, status, tags, image, liveUrl, githubUrl } = Astro.props;

/** True when at least one link is present — drives the footer visibility */
const hasLinks = liveUrl || githubUrl;

/**
 * Maps display tag names to Simple Icons CDN slugs.
 * Tags absent from this map render as text-only pills.
 * CDN URL format: cdn.simpleicons.org/{slug}/{hex-color}
 */
const ICON_SLUGS: Record<string, string> = {
  'Astro':        'astro',
  'Chart.js':     'chartdotjs',
  'Cloudflare':   'cloudflare',
  'FastAPI':      'fastapi',
  'Flask':        'flask',
  'GitHub Pages': 'github',
  'Gmail API':    'gmail',
  'Leaflet':      'leaflet',
  'MDX':          'mdx',
  'Pandas':       'pandas',
  'Playwright':   'playwright',
  'Power BI':     'powerbi',
  'Python':       'python',
  'React':        'react',
  'Stripe':       'stripe',
  'Supabase':     'supabase',
  'Svelte':       'svelte',
  'SwiftData':    'swift',
  'SwiftUI':      'swift',
  'Tailwind':     'tailwindcss',
  'Vanilla JS':   'javascript',
  'iOS':          'apple',
};

/** paper-500 (#9A8A72) for light mode; paper-300 (#D4C5A9) for dark mode */
const ICON_COLOR_LIGHT = '9A8A72';
const ICON_COLOR_DARK  = 'D4C5A9';
---

<article
  class="
    flex flex-col
    bg-paper-50 dark:bg-paper-900
    border border-paper-300 dark:border-paper-700
    overflow-hidden
    transition-colors duration-200
    hover:border-paper-500 dark:hover:border-paper-500
  "
>
  <!-- Preview image — swap out the placeholder src for a real screenshot when ready -->
  <div class="relative w-full aspect-video bg-paper-200 dark:bg-paper-800 overflow-hidden">
    {image ? (
      <img
        src={image}
        alt={`${title} preview`}
        class="w-full h-full object-cover"
        loading="lazy"
      />
    ) : (
      <!-- Fallback if no image is provided yet -->
      <div class="w-full h-full flex items-center justify-center">
        <span class="font-mono text-xs text-paper-400 dark:text-paper-600 tracking-widest uppercase">
          Preview
        </span>
      </div>
    )}
  </div>

  <!-- Card body -->
  <div class="flex flex-col gap-3 p-5 flex-1">
    <!-- Status badge -->
    <StatusBadge status={status} />

    <!-- Project title in Playfair Display for editorial weight -->
    <h3 class="font-display text-xl leading-snug text-paper-800 dark:text-paper-100">
      {title}
    </h3>

    <!-- Description — grows to fill available space, pushing links to the bottom -->
    <p class="text-sm leading-relaxed text-paper-600 dark:text-paper-400 flex-1">
      {description}
    </p>

    <!-- Tech stack tags in IBM Plex Mono; known stacks get a Simple Icons logo -->
    <ul class="flex flex-wrap gap-1.5" aria-label="Tech stack">
      {tags.map((tag) => {
        const slug = ICON_SLUGS[tag];
        return (
          <li class="flex items-center gap-1 font-mono text-[10px] tracking-wide text-paper-500 dark:text-paper-400 bg-paper-200 dark:bg-paper-800 px-2 py-0.5">
            {slug && (
              <>
                {/* Light-mode icon — hidden when .dark is active */}
                <img
                  src={`https://cdn.simpleicons.org/${slug}/${ICON_COLOR_LIGHT}`}
                  width="12"
                  height="12"
                  class="block dark:hidden flex-shrink-0"
                  alt=""
                  aria-hidden="true"
                  loading="lazy"
                  onerror="this.style.display='none'"
                />
                {/* Dark-mode icon — shown only when .dark is active */}
                <img
                  src={`https://cdn.simpleicons.org/${slug}/${ICON_COLOR_DARK}`}
                  width="12"
                  height="12"
                  class="hidden dark:block flex-shrink-0"
                  alt=""
                  aria-hidden="true"
                  loading="lazy"
                  onerror="this.style.display='none'"
                />
              </>
            )}
            {tag}
          </li>
        );
      })}
    </ul>

    <!-- Links only render when URLs are present -->
    {hasLinks && (
      <footer class="flex gap-3 pt-2 border-t border-paper-200 dark:border-paper-800">
        {liveUrl && (
          <a
            href={liveUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="
              font-mono text-[11px] tracking-wide uppercase
              text-rust dark:text-rust-light
              hover:text-rust-dark dark:hover:text-rust
              transition-colors
            "
          >
            View Live ↗
          </a>
        )}
        {githubUrl && (
          <a
            href={githubUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="
              font-mono text-[11px] tracking-wide uppercase
              text-paper-500 dark:text-paper-400
              hover:text-paper-700 dark:hover:text-paper-200
              transition-colors
            "
          >
            GitHub ↗
          </a>
        )}
      </footer>
    )}
  </div>
</article>
