---
/**
 * ProjectCard — a category-colored card for a single project.
 *
 * The card's accent color comes from its category (see src/lib/categories.ts)
 * and is applied consistently: top accent bar, category tag, "view live" link,
 * and the hover glow. Same color everywhere = Gestalt similarity, so visitors
 * can scan the grid and group projects by kind at a glance.
 *
 * Hover: the card lifts, the border and glow take the category hue, and the
 * screenshot zooms slightly. All transitions collapse under reduced motion.
 */
import StatusBadge from './StatusBadge.astro';
import type { Status } from './StatusBadge.astro';
import { CATEGORY_MAP } from '../lib/categories';
import type { CategoryId } from '../lib/categories';

interface Props {
  title: string;
  description: string;
  status: Status;
  category: CategoryId;
  tags: string[];
  image?: string | null;
  /** 'cover' crops a screenshot to fill; 'contain' pads a logo on a light plate */
  imageFit?: 'cover' | 'contain';
  liveUrl?: string | null;
  githubUrl?: string | null;
  /** Id of this project's case-study modal, when it has deep-dive content.
   *  Present → the card shows a "Case study" trigger that opens the modal. */
  detailId?: string | null;
  /** 0-based grid index — drives the staggered scroll-reveal delay */
  index?: number;
}

const {
  title, description, status, category, tags, image,
  imageFit = 'cover', liveUrl, githubUrl, detailId, index = 0,
} = Astro.props;

/** Resolve the category's accent hues (light + dark surface steps) */
const cat = CATEGORY_MAP[category];

/** True when the footer has anything to show — a case-study trigger or a link */
const hasFooter = detailId || liveUrl || githubUrl;

/**
 * Maps display tag names to Simple Icons CDN slugs.
 * Tags absent from this map render as text-only pills.
 * CDN URL format: cdn.simpleicons.org/{slug}/{hex-color}
 */
const ICON_SLUGS: Record<string, string> = {
  'Astro':        'astro',
  'Chart.js':     'chartdotjs',
  'Cloudflare':   'cloudflare',
  'FastAPI':      'fastapi',
  'Flask':        'flask',
  'GitHub Pages': 'github',
  'Gmail API':    'gmail',
  'Leaflet':      'leaflet',
  'MDX':          'mdx',
  'Pandas':       'pandas',
  'pandas':       'pandas',
  'Playwright':   'playwright',
  'Power BI':     'powerbi',
  'Python':       'python',
  'React':        'react',
  'Recharts':     'recharts',
  'Stripe':       'stripe',
  'Supabase':     'supabase',
  'Svelte':       'svelte',
  'SwiftData':    'swift',
  'SwiftUI':      'swift',
  'Tailwind':     'tailwindcss',
  'Vanilla JS':   'javascript',
  'iOS':          'apple',
};

/** Neutral icon tints: ink-mute for light mode, frost-mute for dark mode */
const ICON_COLOR_LIGHT = '8b8894';
const ICON_COLOR_DARK  = '82808e';
---

<!--
  --cat-l / --cat-d hold both surface steps of the accent; the CSS below
  picks whichever matches the active theme into --cat, which everything
  (accent bar, tag, glow, links) then references.
  data-category powers the legend filter on the index page.
-->
<article
  class="project-card group reveal flex flex-col rounded-xl overflow-hidden
         bg-white dark:bg-night-900
         border border-day-200 dark:border-night-700"
  data-category={category}
  style={`--cat-l:${cat.light}; --cat-d:${cat.dark}; --stagger:${index % 3};`}
>
  <!-- Category accent bar — the card's color signature, always visible -->
  <div class="h-1 w-full shrink-0" style="background: var(--cat);" aria-hidden="true"></div>

  <!--
    Preview image with overlaid category tag + status badge.
    'contain' logos sit padded on a white plate in both themes so the full
    wordmark shows and dark mode reads as deliberate, not a bleed.
  -->
  <div
    class:list={[
      'relative w-full aspect-video overflow-hidden',
      image && imageFit === 'contain' ? 'bg-white' : 'bg-day-100 dark:bg-night-800',
    ]}
  >
    {image ? (
      <img
        src={image}
        alt={`${title} preview`}
        class:list={[
          'card-img w-full h-full',
          imageFit === 'contain' ? 'object-contain p-6' : 'object-cover',
        ]}
        loading="lazy"
      />
    ) : (
      <!-- Fallback if no screenshot yet: category-tinted wash + big initial -->
      <div class="card-fallback w-full h-full flex items-center justify-center">
        <span class="font-display text-7xl font-bold select-none" aria-hidden="true">
          {title.charAt(0)}
        </span>
      </div>
    )}

    <!-- Category tag (color + text label, never color alone) -->
    <span
      class="absolute top-3 left-3 z-[2] inline-flex items-center gap-1.5
             font-mono text-[10px] font-medium tracking-[0.12em] uppercase
             text-ink dark:text-frost
             bg-day-50/85 dark:bg-night-900/85 backdrop-blur-sm
             border border-day-200 dark:border-night-700
             rounded-full px-2.5 py-1"
    >
      <span class="w-1.5 h-1.5 rounded-full shrink-0" style="background: var(--cat);"></span>
      {cat.label}
    </span>

    <!-- Status badge, opposite corner -->
    <span class="absolute top-3 right-3 z-[2]">
      <StatusBadge status={status} />
    </span>

    <!--
      When the project has a case study, the whole preview becomes a second
      trigger for it (the footer "Case Study" link is easy to miss). A scrim
      + pill fade in on hover/focus so the affordance is obvious. JS-only, so
      it's hidden without JS like the footer trigger.
    -->
    {detailId && (
      <button
        type="button"
        data-modal-open={detailId}
        class="card-media-trigger card-detail-link absolute inset-0 z-[1]
               flex items-center justify-center"
        aria-label={`View ${title} case study`}
      >
        <span class="card-media-hint" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor"
               stroke-width="2" aria-hidden="true">
            <circle cx="11" cy="11" r="7" />
            <path d="M21 21l-4.3-4.3" stroke-linecap="round" />
          </svg>
          Case Study
        </span>
      </button>
    )}
  </div>

  <!-- Card body -->
  <div class="flex flex-col gap-3 p-5 flex-1">
    <!-- Project title -->
    <h3 class="font-display text-xl font-semibold leading-snug text-ink dark:text-frost">
      {title}
    </h3>

    <!-- Description — grows to fill available space, pushing links down -->
    <p class="text-sm leading-relaxed text-ink-soft dark:text-frost-soft flex-1">
      {description}
    </p>

    <!-- Tech stack tags; known stacks get a Simple Icons logo -->
    <ul class="flex flex-wrap gap-1.5" aria-label="Tech stack">
      {tags.map((tag) => {
        const slug = ICON_SLUGS[tag];
        return (
          <li class="flex items-center gap-1 font-mono text-[10px] tracking-wide
                     text-ink-soft dark:text-frost-soft
                     bg-day-100 dark:bg-night-800 rounded px-2 py-0.5">
            {slug && (
              <>
                {/* Light-mode icon — hidden when .dark is active */}
                <img
                  src={`https://cdn.simpleicons.org/${slug}/${ICON_COLOR_LIGHT}`}
                  width="12"
                  height="12"
                  class="block dark:hidden flex-shrink-0"
                  alt=""
                  aria-hidden="true"
                  loading="lazy"
                  onerror="this.style.display='none'"
                />
                {/* Dark-mode icon — shown only when .dark is active */}
                <img
                  src={`https://cdn.simpleicons.org/${slug}/${ICON_COLOR_DARK}`}
                  width="12"
                  height="12"
                  class="hidden dark:block flex-shrink-0"
                  alt=""
                  aria-hidden="true"
                  loading="lazy"
                  onerror="this.style.display='none'"
                />
              </>
            )}
            {tag}
          </li>
        );
      })}
    </ul>

    <!-- Footer: a case-study trigger (when the project has one) plus links -->
    {hasFooter && (
      <footer class="flex flex-wrap items-center gap-4 pt-3 border-t border-day-200 dark:border-night-700">
        {detailId && (
          <button
            type="button"
            data-modal-open={detailId}
            class="card-detail-link card-live-link font-mono text-[11px] font-medium tracking-wide uppercase
                   inline-flex items-center gap-1"
          >
            Case Study <span class="link-arrow" aria-hidden="true">→</span>
          </button>
        )}
        {liveUrl && (
          <a
            href={liveUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="card-live-link font-mono text-[11px] font-medium tracking-wide uppercase
                   inline-flex items-center gap-1"
          >
            View Live <span class="link-arrow" aria-hidden="true">→</span>
          </a>
        )}
        {githubUrl && (
          <a
            href={githubUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="font-mono text-[11px] tracking-wide uppercase
                   text-ink-mute dark:text-frost-mute
                   hover:text-ink dark:hover:text-frost
                   transition-colors"
          >
            GitHub ↗
          </a>
        )}
      </footer>
    )}
  </div>
</article>

<style>
  /* Theme indirection: --cat resolves to the light or dark step of the
     category hue depending on the active theme class on <html>. */
  .project-card {
    --cat: var(--cat-l);
    transition:
      transform 0.25s ease,
      border-color 0.25s ease,
      box-shadow 0.25s ease;
  }
  :global(.dark) .project-card {
    --cat: var(--cat-d);
  }

  /* Hover: lift + category-colored border and glow. color-mix keeps the
     glow tied to whichever accent the theme resolved. */
  .project-card:hover {
    transform: translateY(-5px);
    border-color: var(--cat);
    box-shadow: 0 12px 32px -8px color-mix(in srgb, var(--cat) 35%, transparent);
  }

  /* Dark surface swallows a drop shadow, so the glow goes neon instead:
     an all-around halo plus a stronger underglow, both in the accent. */
  :global(.dark) .project-card:hover {
    box-shadow:
      0 0 22px -2px color-mix(in srgb, var(--cat) 45%, transparent),
      0 14px 40px -8px color-mix(in srgb, var(--cat) 55%, transparent);
  }

  /* Screenshot zooms slightly on hover — scoped so only the image moves */
  .card-img {
    transition: transform 0.4s ease;
  }
  .project-card:hover .card-img {
    transform: scale(1.045);
  }

  /* No-screenshot fallback: soft wash of the category hue behind a large
     ghosted initial in the same hue — on-brand instead of a gray box. */
  .card-fallback {
    background: linear-gradient(
      135deg,
      color-mix(in srgb, var(--cat) 14%, transparent),
      color-mix(in srgb, var(--cat) 4%, transparent)
    );
  }
  .card-fallback span {
    color: var(--cat);
    opacity: 0.4;
  }

  /* The case-study trigger opens a dialog via JS, so hide it for no-JS
     visitors — the live/GitHub links still cover them. Mirrors the site's
     html.js gating used for reveals and the KPI panel. */
  :global(html:not(.js)) .card-detail-link {
    display: none;
  }

  /* ── Preview-image case-study trigger ──────────────────────────────
     A scrim + pill that fade in when the card is hovered or the button is
     keyboard-focused, so the image reads as clickable without a permanent
     overlay competing with the screenshot. */
  .card-media-trigger {
    cursor: pointer;
  }
  .card-media-trigger::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(22, 21, 29, 0.5), rgba(22, 21, 29, 0) 55%);
    opacity: 0;
    transition: opacity 0.25s ease;
  }
  .card-media-hint {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-family: theme('fontFamily.mono');
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #fff;
    background: var(--cat);
    padding: 0.45rem 0.85rem;
    border-radius: 9999px;
    box-shadow: 0 4px 14px -4px rgba(22, 21, 29, 0.5);
    opacity: 0;
    transform: translateY(6px);
    transition: opacity 0.25s ease, transform 0.25s ease;
  }
  /* Reveal on card hover or keyboard focus of the trigger */
  .project-card:hover .card-media-trigger::before,
  .card-media-trigger:focus-visible::before {
    opacity: 1;
  }
  .project-card:hover .card-media-hint,
  .card-media-trigger:focus-visible .card-media-hint {
    opacity: 1;
    transform: none;
  }
  /* Keyboard focus ring on the otherwise-transparent trigger */
  .card-media-trigger:focus-visible {
    outline: 2px solid var(--cat);
    outline-offset: -2px;
  }

  /* "View Live" wears the category color; its arrow nudges right on hover */
  .card-live-link {
    color: var(--cat);
  }
  .link-arrow {
    display: inline-block;
    transition: transform 0.2s ease;
  }
  .card-live-link:hover .link-arrow {
    transform: translateX(3px);
  }
</style>
