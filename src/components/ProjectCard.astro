---
/**
 * ProjectCard — editorial card for a single project.
 * Image preview at top, status badge, title, description, tech tags, and optional links below.
 */
import StatusBadge from './StatusBadge.astro';
import type { Status } from './StatusBadge.astro';

interface Props {
  title: string;
  description: string;
  status: Status;
  tags: string[];
  image?: string | null;
  liveUrl?: string | null;
  githubUrl?: string | null;
}

const { title, description, status, tags, image, liveUrl, githubUrl } = Astro.props;

/** True when at least one link is present — drives the footer visibility */
const hasLinks = liveUrl || githubUrl;
---

<article
  class="
    flex flex-col
    bg-paper-50 dark:bg-paper-900
    border border-paper-300 dark:border-paper-700
    overflow-hidden
    transition-colors duration-200
    hover:border-paper-500 dark:hover:border-paper-500
  "
>
  <!-- Preview image — swap out the placeholder src for a real screenshot when ready -->
  <div class="relative w-full aspect-video bg-paper-200 dark:bg-paper-800 overflow-hidden">
    {image ? (
      <img
        src={image}
        alt={`${title} preview`}
        class="w-full h-full object-cover"
        loading="lazy"
      />
    ) : (
      <!-- Fallback if no image is provided yet -->
      <div class="w-full h-full flex items-center justify-center">
        <span class="font-mono text-xs text-paper-400 dark:text-paper-600 tracking-widest uppercase">
          Preview
        </span>
      </div>
    )}
  </div>

  <!-- Card body -->
  <div class="flex flex-col gap-3 p-5 flex-1">
    <!-- Status badge -->
    <StatusBadge status={status} />

    <!-- Project title in Playfair Display for editorial weight -->
    <h3 class="font-display text-xl leading-snug text-paper-800 dark:text-paper-100">
      {title}
    </h3>

    <!-- Description — grows to fill available space, pushing links to the bottom -->
    <p class="text-sm leading-relaxed text-paper-600 dark:text-paper-400 flex-1">
      {description}
    </p>

    <!-- Tech stack tags in IBM Plex Mono -->
    <ul class="flex flex-wrap gap-1.5" aria-label="Tech stack">
      {tags.map((tag) => (
        <li class="font-mono text-[10px] tracking-wide text-paper-500 dark:text-paper-500 bg-paper-200 dark:bg-paper-800 px-2 py-0.5">
          {tag}
        </li>
      ))}
    </ul>

    <!-- Links only render when URLs are present -->
    {hasLinks && (
      <footer class="flex gap-3 pt-2 border-t border-paper-200 dark:border-paper-800">
        {liveUrl && (
          <a
            href={liveUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="
              font-mono text-[11px] tracking-wide uppercase
              text-rust dark:text-rust-light
              hover:text-rust-dark dark:hover:text-rust
              transition-colors
            "
          >
            View Live ↗
          </a>
        )}
        {githubUrl && (
          <a
            href={githubUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="
              font-mono text-[11px] tracking-wide uppercase
              text-paper-500 dark:text-paper-400
              hover:text-paper-700 dark:hover:text-paper-200
              transition-colors
            "
          >
            GitHub ↗
          </a>
        )}
      </footer>
    )}
  </div>
</article>
