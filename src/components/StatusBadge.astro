---
/**
 * StatusBadge — a small dot + label chip showing project status.
 * The dot carries the status color; the text label always accompanies it,
 * so meaning is never conveyed by color alone. LIVE dots pulse gently
 * (animation defined globally in Base.astro, disabled for reduced motion).
 */
export type Status = 'live' | 'beta' | 'in-progress' | 'planning';

interface Props {
  status: Status;
}

const { status } = Astro.props;

/**
 * Per-status config: display label, dot color classes, and whether the
 * dot pulses. Status hues are reserved (never reused as category accents).
 */
const config: Record<Status, { label: string; dot: string; pulse: boolean }> = {
  live:          { label: 'Live',        dot: 'bg-status-live',     pulse: true },
  beta:          { label: 'Beta',        dot: 'bg-status-beta',     pulse: false },
  'in-progress': { label: 'In Progress', dot: 'bg-status-progress', pulse: false },
  planning:      { label: 'Planning',    dot: 'bg-status-planning', pulse: false },
};

const { label, dot, pulse } = config[status];
---

<!--
  Frosted chip so the badge stays readable when overlaid on card images.
  backdrop-blur + translucent surface works on both light and dark shots.
-->
<span
  class="
    inline-flex items-center gap-1.5
    font-mono text-[10px] font-medium tracking-[0.12em] uppercase
    text-ink dark:text-frost
    bg-day-50/85 dark:bg-night-900/85 backdrop-blur-sm
    border border-day-200 dark:border-night-700
    rounded-full px-2.5 py-1
  "
>
  <span
    class:list={['w-1.5 h-1.5 rounded-full shrink-0', dot]}
    style={pulse ? 'animation: pulse-ring 2.4s ease-out infinite;' : undefined}
  ></span>
  {label}
</span>
