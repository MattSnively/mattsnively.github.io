---
/**
 * Portfolio home page — single-page layout with Hero, Projects grid, About, and Footer.
 * Projects are driven by the content collection so adding a new one is a JSON file drop.
 */
import Base from '../layouts/Base.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const projects = allProjects.sort((a, b) => a.data.order - b.data.order);
---

<Base>
  <!-- ─── Navigation ──────────────────────────────────────────────────── -->
  <nav
    class="
      fixed top-0 inset-x-0 z-40
      flex items-center justify-between
      px-6 md:px-12 py-4
      border-b border-paper-300 dark:border-paper-800
      bg-paper-100/90 dark:bg-paper-950/90
      backdrop-blur-sm
    "
  >
    <!-- Monogram -->
    <span class="font-mono text-sm tracking-[0.2em] text-paper-600 dark:text-paper-400">
      MS
    </span>

    <div class="flex items-center gap-6">
      <!-- In-page anchor links -->
      <a
        href="#work"
        class="font-mono text-xs tracking-widest uppercase text-paper-500 dark:text-paper-400 hover:text-paper-800 dark:hover:text-paper-100 transition-colors"
      >
        Work
      </a>
      <a
        href="#about"
        class="font-mono text-xs tracking-widest uppercase text-paper-500 dark:text-paper-400 hover:text-paper-800 dark:hover:text-paper-100 transition-colors"
      >
        About
      </a>

      <!-- Dark / light toggle -->
      <button
        id="theme-toggle"
        aria-label="Toggle dark mode"
        class="
          w-8 h-8 flex items-center justify-center
          text-paper-500 dark:text-paper-400
          hover:text-paper-800 dark:hover:text-paper-100
          transition-colors
        "
      >
        <!-- Sun icon (shown in dark mode) -->
        <svg
          id="icon-sun"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          class="w-4 h-4 hidden dark:block"
          aria-hidden="true"
        >
          <circle cx="12" cy="12" r="4" />
          <path d="M12 2v2M12 20v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M2 12h2M20 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42" />
        </svg>
        <!-- Moon icon (shown in light mode) -->
        <svg
          id="icon-moon"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          class="w-4 h-4 block dark:hidden"
          aria-hidden="true"
        >
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- ─── Hero ─────────────────────────────────────────────────────────── -->
  <section
    class="
      flex flex-col justify-center
      px-6 md:px-12 pt-28 pb-14
      max-w-4xl mx-auto
    "
  >
    <!-- Classification-stamp label above the name -->
    <p class="font-mono text-xs tracking-[0.25em] uppercase text-rust dark:text-rust-light mb-6">
      Data Viz Consultant · Software Developer · Data Journalist 
    </p>

    <h1
      class="
        font-display text-5xl md:text-7xl font-black leading-[1.05]
        text-paper-900 dark:text-paper-50
        mb-8
      "
    >
      Matt Snively
    </h1>

    <p
      class="
        text-lg md:text-xl leading-relaxed
        text-paper-600 dark:text-paper-400
        max-w-xl mb-10
      "
    >
      I turn unstructured data into actionable business insights for my day job, and in my spare time I noodle on various projects that pique my interests: sports, politics, cars, education... if inspiration strikes, there's an "in-progress" project that follows.
    </p>

    <div class="flex flex-wrap gap-4">
      <a
        href="https://github.com/MattSnively"
        target="_blank"
        rel="noopener noreferrer"
        class="
          font-mono text-xs tracking-widest uppercase
          bg-rust dark:bg-rust-light
          text-paper-50
          border border-rust dark:border-rust-light
          px-5 py-2.5
          hover:bg-rust-dark dark:hover:bg-rust
          hover:border-rust-dark dark:hover:border-rust
          transition-colors
        "
      >
        GitHub ↗
      </a>
      <a
        href="mailto:mattsnively@gmail.com"
        class="
          font-mono text-xs tracking-widest uppercase
          text-paper-500 dark:text-paper-400
          px-5 py-2.5
          hover:text-paper-800 dark:hover:text-paper-100
          transition-colors
        "
      >
        Contact →
      </a>
    </div>
  </section>

  <!-- Horizontal rule — editorial section divider -->
  <hr class="border-paper-300 dark:border-paper-800 mx-6 md:mx-12" />

  <!-- ─── Projects ──────────────────────────────────────────────────────── -->
  <section id="work" class="px-6 md:px-12 py-12 max-w-6xl mx-auto w-full">
    <!-- Section header with classification-style label -->
    <div class="flex items-baseline gap-4 mb-8">
      <span class="font-mono text-[10px] tracking-[0.25em] uppercase text-rust dark:text-rust-light">
        PROJECTS
      </span>
      <h2 class="font-display text-3xl md:text-4xl font-bold text-paper-900 dark:text-paper-50">
        Work
      </h2>
    </div>

    <!--
      Responsive grid: 1 col on mobile → 2 cols on md → 3 cols on lg.
      Cards use flex-col internally so descriptions expand and links stay at the bottom.
    -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {projects.map((project) => (
        <ProjectCard
          title={project.data.title}
          description={project.data.description}
          status={project.data.status}
          tags={project.data.tags}
          image={project.data.image}
          liveUrl={project.data.liveUrl}
          githubUrl={project.data.githubUrl}
        />
      ))}
    </div>
  </section>

  <hr class="border-paper-300 dark:border-paper-800 mx-6 md:mx-12" />

  <!-- ─── About ─────────────────────────────────────────────────────────── -->
  <section id="about" class="px-6 md:px-12 py-12 max-w-4xl mx-auto w-full">
    <div class="flex items-baseline gap-4 mb-8">
      <span class="font-mono text-[10px] tracking-[0.25em] uppercase text-rust dark:text-rust-light">
        ABOUT
      </span>
      <h2 class="font-display text-3xl md:text-4xl font-bold text-paper-900 dark:text-paper-50">
        Background
      </h2>
    </div>

    <div class="space-y-5 text-paper-600 dark:text-paper-400 leading-relaxed max-w-2xl">
      <p>
        I'm a developer and data journalist based in Missouri. I build public-interest tools
        at the intersection of civic technology, data analysis, and software engineering —
        from redistricting transparency sites to political accountability trackers to iOS apps.
      </p>
      <p>
        I believe good software should be fair, open, and legible to the people it serves.
        The work here is a mix of production products, ongoing research, and experiments
        that scratch my own itch.
      </p>
    </div>
  </section>

  <!-- ─── Footer ────────────────────────────────────────────────────────── -->
  <footer
    class="
      border-t border-paper-300 dark:border-paper-800
      px-6 md:px-12 py-8
      flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4
    "
  >
    <p class="font-mono text-xs tracking-wide text-paper-400 dark:text-paper-500">
      © 2026 Matt Snively
    </p>
    <a
      href="mailto:mattsnively@gmail.com"
      class="font-mono text-xs tracking-wide text-paper-500 dark:text-paper-400 hover:text-rust dark:hover:text-rust-light transition-colors"
    >
      mattsnively@gmail.com
    </a>
  </footer>
</Base>

<!-- Theme toggle — reads/writes localStorage and flips the `dark` class on <html> -->
<script>
  const btn = document.getElementById('theme-toggle');
  btn?.addEventListener('click', () => {
    const isDark = document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
  });
</script>
