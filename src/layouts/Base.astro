---
/**
 * Base layout — shared <head>, font imports, animated background layers,
 * dark-mode init, global animation keyframes, and the scroll-reveal observer.
 * All pages wrap their content in this layout.
 */
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Matt Snively — Data, Code & Civic Tech',
  description = 'Developer and data journalist building civic accountability tools, analytics dashboards, and mobile apps.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />

    <!-- Space Grotesk (display) + Inter (body) + JetBrains Mono (labels/tags) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <!--
      Inline script runs before first paint:
      1. Applies the theme class (prevents a flash of the wrong theme). Dark is
         the default; only an explicit light choice (saved via the toggle)
         opts out, so first-time visitors always land in dark mode.
      2. Stamps `js` on <html> so reveal-animation styles only hide content
         when JavaScript is actually available to un-hide it (no-JS fallback).
    -->
    <script is:inline>
      (function () {
        if (localStorage.getItem('theme') !== 'light') {
          document.documentElement.classList.add('dark');
        }
        document.documentElement.classList.add('js');
      })();
    </script>

    <!--
      Global animation system.
      Every animation here is gated behind prefers-reduced-motion at the
      bottom of the block — motion-sensitive visitors get a fully static page.
    -->
    <style is:global>
      /* ── Scroll-reveal ─────────────────────────────────────────────────
         Elements tagged .reveal start invisible and rise into place when
         the IntersectionObserver below adds .in. The hidden initial state
         only applies when <html> has the .js class, so content is never
         invisible for no-JS visitors. --stagger (an integer set inline)
         delays children so grids cascade in. */
      html.js .reveal {
        opacity: 0;
        transform: translateY(18px);
      }
      html.js .reveal.in {
        opacity: 1;
        transform: none;
        transition:
          opacity 0.6s cubic-bezier(0.22, 1, 0.36, 1),
          transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
        transition-delay: calc(var(--stagger, 0) * 90ms);
      }

      /* ── Hero chart keyframes ──────────────────────────────────────────
         draw-line: strokes a path in (used with pathLength=1 + dasharray 1)
         grow-bar:  bars rise from the baseline
         pop-dot:   scatter points scale in
         float-dot: gentle perpetual bob after the pop
         fade-in:   generic late fade for annotations/tooltips */
      @keyframes draw-line {
        to { stroke-dashoffset: 0; }
      }
      @keyframes grow-bar {
        from { transform: scaleY(0); }
        to   { transform: scaleY(1); }
      }
      @keyframes pop-dot {
        0%   { transform: scale(0); }
        70%  { transform: scale(1.35); }
        100% { transform: scale(1); }
      }
      @keyframes float-dot {
        0%, 100% { translate: 0 0; }
        50%      { translate: 0 -5px; }
      }
      @keyframes fade-in {
        from { opacity: 0; }
        to   { opacity: 1; }
      }

      /* ── Gradient name shimmer ─────────────────────────────────────────
         The H1 gets a wide 4-hue gradient that slowly pans back and forth. */
      @keyframes gradient-pan {
        0%, 100% { background-position: 0% 50%; }
        50%      { background-position: 100% 50%; }
      }

      /* ── Live-status pulse ─────────────────────────────────────────────
         The green dot on LIVE badges breathes via an expanding ring. */
      @keyframes pulse-ring {
        0%   { box-shadow: 0 0 0 0 rgba(12, 163, 12, 0.45); }
        70%  { box-shadow: 0 0 0 6px rgba(12, 163, 12, 0); }
        100% { box-shadow: 0 0 0 0 rgba(12, 163, 12, 0); }
      }

      /* ── Background glow drift ─────────────────────────────────────────
         The big soft color blobs behind the page wander very slowly. */
      @keyframes drift-a {
        0%, 100% { translate: 0 0; }
        50%      { translate: 60px 40px; }
      }
      @keyframes drift-b {
        0%, 100% { translate: 0 0; }
        50%      { translate: -50px -30px; }
      }

      /* ── Reduced motion: kill everything ───────────────────────────────
         Animations collapse to their end state; reveals render visible. */
      @media (prefers-reduced-motion: reduce) {
        *,
        *::before,
        *::after {
          animation-duration: 0.01ms !important;
          animation-delay: 0ms !important;
          animation-iteration-count: 1 !important;
          transition-duration: 0.01ms !important;
        }
        html.js .reveal {
          opacity: 1;
          transform: none;
        }
      }
    </style>
  </head>

  <body
    class="
      bg-day-50 dark:bg-night-950
      text-ink dark:text-frost
      font-sans antialiased
      transition-colors duration-300
    "
  >
    <!--
      Background layer 1 — graph-paper dot grid.
      A quiet nod to chart paper: the whole site sits on a plotting surface.
      Pure CSS radial-gradient dots, so it costs nothing and themes cleanly.
    -->
    <div
      aria-hidden="true"
      class="fixed inset-0 z-0 pointer-events-none dot-grid"
    ></div>

    <!--
      Background layer 2 — two large blurred color glows (blue + magenta from
      the category palette) drifting very slowly behind the content. They give
      the page depth (Gestalt figure/ground) without competing with the data.
    -->
    <div aria-hidden="true" class="fixed inset-0 z-0 pointer-events-none overflow-hidden">
      <div class="glow glow-a"></div>
      <div class="glow glow-b"></div>
    </div>

    <style>
      /* Dot grid: 1px dots on a 28px lattice, fading out toward the bottom */
      .dot-grid {
        background-image: radial-gradient(circle, rgba(22, 21, 29, 0.13) 1px, transparent 1px);
        background-size: 28px 28px;
        mask-image: linear-gradient(to bottom, black 0%, black 60%, transparent 100%);
        -webkit-mask-image: linear-gradient(to bottom, black 0%, black 60%, transparent 100%);
      }
      :global(.dark) .dot-grid {
        background-image: radial-gradient(circle, rgba(242, 242, 245, 0.09) 1px, transparent 1px);
      }

      /* Color glows: huge blurred radials in palette hues, barely-there */
      .glow {
        position: absolute;
        width: 560px;
        height: 560px;
        border-radius: 9999px;
        filter: blur(110px);
      }
      .glow-a {
        top: -180px;
        right: -120px;
        background: radial-gradient(circle, rgba(42, 120, 214, 0.16), transparent 70%);
        animation: drift-a 26s ease-in-out infinite;
      }
      .glow-b {
        top: 45%;
        left: -180px;
        background: radial-gradient(circle, rgba(232, 123, 164, 0.13), transparent 70%);
        animation: drift-b 32s ease-in-out infinite;
      }
      :global(.dark) .glow-a {
        background: radial-gradient(circle, rgba(57, 135, 229, 0.14), transparent 70%);
      }
      :global(.dark) .glow-b {
        background: radial-gradient(circle, rgba(213, 81, 129, 0.11), transparent 70%);
      }
    </style>

    <div class="relative z-10">
      <slot />
    </div>

    <!--
      Scroll-reveal observer — adds .in to every .reveal element the first
      time it enters the viewport (12% visible). Runs once per element, then
      unobserves so scrolling back up doesn't re-hide anything.
    -->
    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              entry.target.classList.add('in');
              observer.unobserve(entry.target);
            }
          }
        },
        { threshold: 0.12 },
      );
      document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
    </script>
  </body>
</html>
